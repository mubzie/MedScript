{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/build-contracts.sh",
            "timeout": 300,
            "statusMessage": "Building modified contracts..."
          }
        ]
      }
    ]
  }
}
